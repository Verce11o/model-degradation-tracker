{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$PLUGIN_ROOT\" ]; then node \"$PLUGIN_ROOT/hooks/session_start.js\"; fi",
            "timeout": 7,
            "statusMessage": "checking model performance"
          }
        ]
      }
    ]
  }
}
